{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Tool Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "type",
    "description",
    "author"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "工具/技巧名称（英文，无空格）"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "tool",
        "skill"
      ]
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object"
        }
      ]
    },
    "python_version": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readme": {
      "type": "string"
    }
  }
}